---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';

const GUIA_URL = '/guia-inss-5-passos.pdf';

const proximosPassos = [
  {
    slug: '/blog/como-se-aposentar-pelo-inss-em-2026',
    titulo: 'Como se aposentar pelo INSS em 2026',
    desc: 'Regras atualizadas, tipos de aposentadoria e o passo a passo completo do pedido.',
  },
  {
    slug: '/blog/como-calcular-tempo-de-contribuicao-inss',
    titulo: 'Como calcular seu tempo de contribuição',
    desc: 'Descubra exatamente quanto tempo você já tem e o que ainda falta.',
  },
  {
    slug: '/blog/como-corrigir-erros-no-cnis',
    titulo: 'Como corrigir erros no CNIS',
    desc: 'O passo a passo completo para cada tipo de erro encontrado no seu extrato.',
  },
];
---

<BaseLayout
	title={`Guia enviado | ${SITE_TITLE}`}
	description="Seu guia gratuito já está disponível para download."
>
	<section class="hero-gradient px-4 py-20">
		<div class="mx-auto max-w-2xl text-center">
			<p class="mb-4 text-sm font-semibold tracking-widest text-accent uppercase">Tudo certo</p>
			<h1 class="font-serif text-4xl leading-tight font-semibold text-balance text-fg">
				Seu guia está liberado
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-muted">
				Recebemos seus dados. Clique no botão abaixo para baixar agora o guia "Como consultar e
				corrigir seu INSS em 5 passos".
			</p>

			<a
				href={GUIA_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-4 text-base font-semibold text-bg no-underline transition-colors hover:bg-accent-hover"
			>
				Baixar o guia agora
			</a>

			<p class="mt-4 text-sm text-subtle">
				Fique tranquilo: você também vai receber uma cópia no seu e-mail.
			</p>
		</div>
	</section>

	<section class="bg-surface px-4 py-16">
		<div class="mx-auto max-w-3xl">
			<h2 class="text-center font-serif text-2xl font-semibold text-fg">
				Continue se preparando para sua aposentadoria
			</h2>
			<p class="mt-3 text-center text-sm text-muted">
				Esses artigos vão te ajudar a aplicar o que está no guia.
			</p>
			<div class="mt-10 grid gap-4 sm:grid-cols-3">
				{
					proximosPassos.map((post) => (
						<a
							href={post.slug}
							class="group rounded-lg border border-border bg-bg-card p-5 no-underline transition-colors hover:border-accent/50"
						>
							<h3 class="font-serif text-base font-semibold leading-snug text-fg transition-colors group-hover:text-accent">
								{post.titulo}
							</h3>
							<p class="mt-2 text-sm leading-relaxed text-muted">{post.desc}</p>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="px-4 py-16">
		<div class="mx-auto max-w-2xl">
			<div class="rounded-xl border border-accent/30 bg-accent-subtle p-8 text-center">
				<p class="mb-3 text-sm font-semibold tracking-widest text-accent uppercase">
					Próximo passo
				</p>
				<h2 class="font-serif text-2xl font-semibold text-fg">
					Quer uma análise completa do seu caso?
				</h2>
				<p class="mx-auto mt-4 max-w-lg leading-relaxed text-muted">
					Uma consultoria previdenciária pode analisar seu histórico completo no CNIS, calcular
					seu tempo real de contribuição e apontar a regra mais vantajosa para o seu pedido de
					aposentadoria.
				</p>

				<a
					href="https://exemplo.com/consultoria-previdenciaria"
					target="_blank"
					rel="noopener noreferrer sponsored"
					class="mt-8 inline-block rounded-lg bg-accent px-8 py-4 text-base font-semibold text-bg no-underline transition-colors hover:bg-accent-hover"
				>
					Falar com especialista
				</a>

				<p class="mt-4 text-xs text-subtle">
					Link de afiliado — você não paga nada a mais por usar.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>