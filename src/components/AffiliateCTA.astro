---
import type { AffiliateCta } from '../content.config';

interface Props extends AffiliateCta {}

const { title, description, buttonText, url } = Astro.props;
---

<aside
	class="my-10 rounded-xl border border-accent/30 bg-accent-subtle p-6 sm:p-8"
	aria-label="Recomendação de produto"
>
	<p class="text-xs font-semibold tracking-widest text-accent uppercase">Recomendação</p>
	<h3 class="mt-2 font-serif text-xl font-semibold text-fg sm:text-2xl">{title}</h3>
	{description && <p class="mt-3 text-sm leading-relaxed text-muted">{description}</p>}
	<a
		href={url}
		target="_blank"
		rel="noopener noreferrer sponsored"
		class="mt-5 inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-bg no-underline transition-colors hover:bg-accent-hover"
	>
		{buttonText}
	</a>
	<p class="mt-3 text-xs text-subtle">
		Link de afiliado — você não paga nada a mais por usar.
	</p>
</aside>
