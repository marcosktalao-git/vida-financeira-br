---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const normalizedHref = href?.toString().replace(/\/$/, '') || '';
const normalizedPath = pathname.replace(/\/$/, '') || '/';
const isActive =
	normalizedHref === normalizedPath ||
	(normalizedHref !== '/' && normalizedPath.startsWith(normalizedHref));
---

<a
	href={href}
	class:list={[
		'rounded-md px-3 py-2 text-sm font-medium text-muted no-underline transition-colors hover:text-fg',
		{ 'text-accent!': isActive },
		className,
	]}
	{...props}
>
	<slot />
</a>
