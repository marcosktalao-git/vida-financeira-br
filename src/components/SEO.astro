---
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import {
	absoluteUrl,
	buildArticleJsonLd,
	buildBreadcrumbJsonLd,
	type ArticleSeoData,
	type BreadcrumbItem,
	type SeoType,
} from '../utils/seo';

interface Props {
	title: string;
	description?: string;
	headline?: string;
	image?: ImageMetadata;
	type?: SeoType;
	keywords?: string[];
	article?: ArticleSeoData;
	breadcrumbs?: BreadcrumbItem[];
}

const {
	title,
	description = SITE_DESCRIPTION,
	headline,
	image,
	type = 'website',
	keywords = [],
	article,
	breadcrumbs = [],
} = Astro.props;

const articleHeadline = headline ?? title;

const canonicalUrl = absoluteUrl(Astro.url.pathname, Astro.site);
const imageUrl = image
	? absoluteUrl(image.src, Astro.site)
	: absoluteUrl(FallbackImage.src, Astro.site);

const metaKeywords = keywords.length > 0 ? keywords.join(', ') : undefined;

const jsonLd: Record<string, unknown>[] = [];

if (type === 'article' && article) {
	jsonLd.push(
		buildArticleJsonLd({
			title: articleHeadline,
			description,
			imageUrl,
			canonicalUrl,
			pubDate: article.pubDate,
			updatedDate: article.updatedDate,
		}),
	);
}

if (breadcrumbs.length > 0) {
	jsonLd.push(buildBreadcrumbJsonLd(breadcrumbs, Astro.site));
}
---

<!-- Google Search Console -->
<meta name="google-site-verification" content="WGYg0AI4ij_PC2rfcJ_W4lgWFNz2tiiyyrC7z4w93oY" />
<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{metaKeywords && <meta name="keywords" content={metaKeywords} />}

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="pt_BR" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
{
	type === 'article' && article && (
		<>
			<meta property="article:published_time" content={article.pubDate.toISOString()} />
			{
				article.updatedDate && (
					<meta property="article:modified_time" content={article.updatedDate.toISOString()} />
				)
			}
		</>
	)
}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- JSON-LD Structured Data -->
{
	jsonLd.map((schema) => (
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	))
}
