---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import AdSenseSlot from '../components/AdSenseSlot.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import EbookBanner from '../components/EbookBanner.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';
import { SITE_TITLE, tagToSlug } from '../consts';

interface Props extends CollectionEntry<'blog'>['data'] {
	slug: string;
}

const {
	slug,
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	keywords,
	affiliate_cta,
} = Astro.props;

const breadcrumbs = [
	{ name: 'Home', path: '/' },
	{ name: 'Artigos', path: '/blog/' },
	{ name: title, path: `/blog/${slug}/` },
];
---

<BaseLayout
	title={`${title} | ${SITE_TITLE}`}
	headline={title}
	description={description}
	image={heroImage}
	type="article"
	keywords={tags}
	article={{ pubDate, updatedDate }}
	breadcrumbs={breadcrumbs}
>
	<article class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<header class="mx-auto max-w-3xl text-center">
			{
				tags && tags.length > 0 && (
					<div class="mb-4 flex flex-wrap justify-center gap-2">
						{tags.map((tag) => (
							<a
								href={`/categoria/${tagToSlug(tag)}/`}
								class="rounded-full bg-accent-subtle px-3 py-1 text-xs font-medium text-accent no-underline transition-colors hover:bg-accent/20"
							>
								{tag}
							</a>
						))}
					</div>
				)
			}
			<h1 class="font-serif text-3xl leading-tight font-semibold text-balance text-fg sm:text-4xl lg:text-5xl">
				{title}
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-muted">{description}</p>
			<div class="mt-6 flex flex-wrap items-center justify-center gap-3 text-sm text-subtle">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<span>
							· Atualizado em <FormattedDate date={updatedDate} />
						</span>
					)
				}
			</div>
		</header>

		{
			heroImage && (
				<div class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-xl border border-border">
					<Image
						src={heroImage}
						alt=""
						width={1020}
						height={510}
						class="h-auto w-full object-cover"
					/>
				</div>
			)
		}

		<div class="mx-auto mt-10 max-w-3xl">
			<AdSenseSlot position="header" />
		</div>

		<div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-12">
			<div class="min-w-0">
				<div class="prose-custom reading-width">
					<slot />
				</div>

				{
					affiliate_cta && (
						<div class="reading-width">
							<AffiliateCTA {...affiliate_cta} />
						</div>
					)
				}

				<div class="reading-width">
					<EbookBanner />
				</div>

				{
					keywords && keywords.length > 0 && (
						<footer class="reading-width mt-10 border-t border-border-subtle pt-6">
							<p class="text-xs font-semibold tracking-widest text-subtle uppercase">
								Palavras-chave
							</p>
							<p class="mt-2 text-sm text-muted">{keywords.join(' · ')}</p>
						</footer>
					)
				}
			</div>

			<aside class="hidden lg:block">
				<div class="sticky top-24 space-y-8">
					<AdSenseSlot position="sidebar" />

					<div class="rounded-xl border border-border bg-bg-card p-5">
						<p class="text-xs font-semibold tracking-widest text-subtle uppercase">Neste artigo</p>
						<p class="mt-2 text-sm leading-relaxed text-muted">
							Conteúdo prático para quem busca renda extra sem largar o emprego.
						</p>
						<a href="/blog/" class="mt-3 inline-block text-sm font-medium no-underline">
							Ver mais artigos →
						</a>
					</div>
				</div>
			</aside>
		</div>

		<div class="mt-10 lg:hidden">
			<AdSenseSlot position="sidebar" />
		</div>
	</article>
</BaseLayout>
